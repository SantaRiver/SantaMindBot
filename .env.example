# Токен бота от @BotFather
BOT_TOKEN=your_bot_token_here

# ID чата "Мысли" — получить через @userinfobot
CHAT_ID=your_chat_id_here

# GitHub Personal Access Token (scope: repo)
GITHUB_TOKEN=ghp_xxxxxxxxxxxx

# Репозиторий с Obsidian-хранилищем
GITHUB_REPO=username/my-obsidian-vault

# Ветка (обычно main или master)
GITHUB_BRANCH=main

# Путь к папке inbox внутри репо
INBOX_PATH=00_inbox
